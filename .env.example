# ==================== Zixo App Environment Variables ====================
# Copy this file to .env.local and fill in your Firebase credentials

# ==================== Firebase (Required) ====================
# Get these from Firebase Console > Project Settings > Your apps > Web app

# Firebase Realtime Database Secret (server-side only)
FIREBASE_DATABASE_SECRET=your_database_secret_here

# Firebase Service Account (server-side only)
FIREBASE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_SERVICE_ACCOUNT_PROJECT_ID=your-project-id
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Copy the "private_key" field from the downloaded JSON
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"

# FCM VAPID Key (for push notifications)
NEXT_PUBLIC_FCM_VAPID_KEY=your_vapid_key_here

# Firebase Realtime Database URL
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Firebase Storage Bucket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Firebase Project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ==================== Cloudflare R2 Storage (Optional) ====================
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-r2-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ==================== Database (Optional) ====================
DATABASE_URL=file:./db/custom.db
