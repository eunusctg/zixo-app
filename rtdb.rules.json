{
  "rules": {
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "calls": {
      ".read": "auth != null",
      "$callId": {
        ".read": "auth != null",
        ".write": "auth != null && (data.child('callerId').val() == auth.uid || data.child('receiverId').val() == auth.uid || newData.child('callerId').val() == auth.uid || newData.child('receiverId').val() == auth.uid)"
      }
    },
    "notifications": {
      "$tokenPrefix": {
        ".read": "auth != null",
        "$notifId": {
          ".write": "auth != null"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "usernames": {
      ".read": "auth != null",
      "$username": {
        ".write": "auth != null"
      }
    }
  }
}
