rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isChatParticipant(chatData) { return isAuth() && chatData.participants.hasAny([request.auth.uid]); }
    function isCreatingParticipant() { return isAuth() && request.resource.data.participants.hasAny([request.auth.uid]); }

    // Users collection - anyone authenticated can read, owner can write, admin can do anything
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // Usernames mapping - for user search
    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth() && request.auth.uid == resource.data.uid;
    }

    // Chats collection
    match /chats/{chatId} {
      allow create: if isAuth() && isCreatingParticipant();
      allow read: if isAuth() && isChatParticipant(resource.data);
      allow update: if isAuth() && isChatParticipant(resource.data) && isChatParticipant(request.resource.data);
      allow delete: if isAuth() && isChatParticipant(resource.data) || isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() && isChatParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isAuth() && isChatParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data) && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() && isChatParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data) && resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid || isAdmin();
      }
    }

    // Call records
    match /calls/{callId} {
      allow read: if isAuth() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid) || isAdmin();
      allow create: if isAuth() && (request.resource.data.callerId == request.auth.uid || request.resource.data.receiverId == request.auth.uid);
      allow delete: if isAuth() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid) || isAdmin();
    }

    // Call signaling
    match /calls_signaling/{callId} {
      allow read: if isAuth() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if isAuth() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid) || isAdmin();
    }

    // FCM tokens
    match /fcmTokens/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }
  }
}
